{
  "profile_name": "gemini_mondrian_man_a4",
  "project": "R.O.B Ross",
  "style": "gemini_mondrian",
  "canvas": {
    "name": "A4 portrait",
    "width_mm": 210.0,
    "height_mm": 297.0,
    "margin_mm": 10.0,
    "origin": "top-left"
  },
  "source_image": {
    "path": "Image_Process/assets/images.jpeg",
    "downscale_max_dimension_px": 1024
  },
  "gemini": {
    "model": "gemini-2.5-flash-image",
    "prompt": "Redraw this photo in a Piet Mondrian / De Stijl painting style: simplify everything into flat solid color regions using only white, black, and blocks of pure red, blue, and yellow, separated by bold black grid lines. The subject and composition should remain recognizable as the original photo - just rendered with Mondrian's flat color-block technique. No gradients, no textures, no photographic shading."
  },
  "palette": {
    "colors": [
      {
        "name": "white",
        "hex": "#ffffff"
      },
      {
        "name": "yellow",
        "hex": "#f1c40f"
      },
      {
        "name": "red",
        "hex": "#d62828"
      },
      {
        "name": "blue",
        "hex": "#1d3557"
      },
      {
        "name": "black",
        "hex": "#000000"
      }
    ],
    "color_space": "lab"
  },
  "segmentation": {
    "min_region_area_mm2": 30.0,
    "morph_open_kernel_px": 3,
    "skip_white_regions": true
  },
  "path_generation": {
    "tool_width_mm": 3.0,
    "stroke_overlap_ratio": 0.15,
    "mask_erosion_mm": 1.0,
    "home_position_mm": [
      10.0,
      10.0
    ]
  },
  "border_generation": {
    "draw_borders": true,
    "simplify_epsilon_ratio": 0.0015
  },
  "output": {
    "directory": "output/gemini_mondrian_man_a4",
    "gemini_output_image_file": "gemini_styled.png",
    "painting_paths_file": "gemini_mondrian_man_painting_paths.json",
    "preview_svg_file": "gemini_mondrian_man_path_preview.svg",
    "quantized_preview_png_file": "gemini_mondrian_man_quantized_preview.png"
  }
}
